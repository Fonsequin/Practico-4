#include <iostream>
using namespace std;

int cargadordevector(int vectorr[], int cantidadd);
int ordenado(int vectorr[], int cantidadd);

int main()
{
    int resultado = 2;
    int cantidad = 10;
    int vectorsito[cantidad];
    cargadordevector(vectorsito, cantidad);
    resultado = ordenado(vectorsito, cantidad);
    if(resultado == 0)
    {
        cout << "La secuencia ingresada no esta ordenada de menor a mayor" << endl;
    }
    if(resultado == 1)
    {
        cout << "Los numeros ingresados estan ordenados de menor a mayor" << endl;
    }
    return 0;
}

int cargadordevector(int vectorr[], int cantidadd)
{
    for(int i = 0; i < cantidadd; i++)
    {
        cout << "Ingrese el numero: ";
        cin >> vectorr[i];
    }
    return vectorr[cantidadd];
}

int ordenado(int vectorr[], int cantidadd)
{
    int resultado = 2;
    for(int i = 0; i < 9; i++)
    {
        if(vectorr[i] > vectorr[i + 1]) 
        {
            resultado = 0;
            return resultado;
        }
    }
    resultado = 1;
    return resultado;
}
